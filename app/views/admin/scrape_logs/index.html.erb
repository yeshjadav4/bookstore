<div class="mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Scrape Logs</h1>
  <p class="text-slate-500 mt-1">History of all scrape attempts (latest 100)</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <table class="w-full">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">URL</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Books Found</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Duration</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Time</th>
        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Error</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @scrape_logs.each do |log| %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-4 text-sm text-slate-700 truncate max-w-xs">
            <%= log.scraping_url&.display_name %>
          </td>
          <td class="px-6 py-4">
            <% if log.success? %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Success</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Failed</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-slate-600 font-medium"><%= log.books_found %></td>
          <td class="px-6 py-4 text-sm text-slate-500"><%= log.duration_seconds ? "#{log.duration_seconds.round(1)}s" : "-" %></td>
          <td class="px-6 py-4 text-sm text-slate-500"><%= time_ago_in_words(log.created_at) %> ago</td>
          <td class="px-6 py-4 text-xs text-red-500 truncate max-w-xs"><%= log.error_message %></td>
        </tr>
      <% end %>

      <% if @scrape_logs.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-12 text-center text-slate-400">
            <p class="text-lg font-medium">No scrape logs yet</p>
            <p class="mt-1">Logs appear here after scraping runs.</p>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= form_with model: [:admin, scraping_url], class: "space-y-6" do |f| %>
  <% if scraping_url.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg">
      <h3 class="font-medium mb-2">Please fix the following errors:</h3>
      <ul class="list-disc pl-5 text-sm">
        <% scraping_url.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :url, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :url, placeholder: "https://www.taxmann.com/bookstore/product/...",
        class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    <p class="text-xs text-slate-400 mt-1">Paste a Taxmann bookstore product or listing URL</p>
  </div>

  <div>
    <%= f.label :url_type, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :url_type, ScrapingUrl.url_types.keys.map { |t| [t.capitalize, t] },
        {}, class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    <p class="text-xs text-slate-400 mt-1"><strong>Product</strong> = single book page. <strong>Listing</strong> = category page with multiple books.</p>
  </div>

  <div>
    <%= f.label :label, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :label, placeholder: "e.g. GST Books, Income Tax 2026",
        class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-slate-800 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    <p class="text-xs text-slate-400 mt-1">Optional friendly name for this URL</p>
  </div>

  <div class="flex items-center space-x-3">
    <%= f.check_box :active, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4" %>
    <%= f.label :active, "Active (include in scheduled scrapes)", class: "text-sm text-slate-700" %>
  </div>

  <div class="flex items-center space-x-3 pt-4">
    <%= f.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-2.5 rounded-lg transition shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", admin_scraping_urls_path, class: "text-slate-500 hover:text-slate-700 font-medium px-4 py-2.5 transition" %>
  </div>
<% end %>

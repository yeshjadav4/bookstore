<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Book Images</h1>
    <p class="text-slate-500 mt-1"><%= @book.title %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "Back to Book", edit_admin_book_path(@book),
        class: "text-slate-600 hover:text-slate-900 font-medium px-4 py-2.5 rounded-lg bg-slate-100 hover:bg-slate-200 transition" %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
  <% if @book_images.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      <% @book_images.each do |img| %>
        <div class="border border-slate-200 rounded-lg overflow-hidden bg-slate-50">
          <div class="aspect-[3/4] flex items-center justify-center p-2 bg-white">
            <img src="<%= img.image_url %>" alt=""
                 class="max-h-full max-w-full object-contain"
                 loading="lazy" />
          </div>
          <div class="px-3 py-2 space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-xs text-slate-600 font-medium">Sequence: <%= img.sequence %></span>
              <%= button_to "Delete",
                  admin_book_book_image_path(@book, img),
                  method: :delete,
                  form: { class: "inline" },
                  data: { turbo_confirm: "Delete image sequence #{img.sequence}?" },
                  class: "text-xs font-semibold text-red-600 hover:text-red-800 bg-transparent border-0 p-0 cursor-pointer" %>
            </div>
            <div class="text-[11px] text-slate-500 break-all">
              <%= img.image_url %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500">No images found for this book.</p>
  <% end %>
</div>


<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>Taxmann Bookstore</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gradient-to-br from-slate-50 via-white to-indigo-50 min-h-screen">
    <nav class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <%= link_to "Taxmann Bookstore", root_path, class: "text-white font-bold text-xl tracking-wide hover:text-yellow-200 transition" %>
          </div>
          <div class="flex items-center space-x-6">
            <%= link_to "Books", books_path, class: "text-white/90 hover:text-white font-medium transition" %>
            <%= link_to "Export CSV", export_books_path, class: "text-white/90 hover:text-white font-medium transition" %>
            <%= link_to "Admin", admin_scraping_urls_path, class: "bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-white/30 transition" %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-lg flex items-center justify-between" role="alert">
          <span><%= notice %></span>
          <button type="button" class="text-emerald-500 hover:text-emerald-700" onclick="this.parentElement.remove()">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          </button>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <footer class="bg-gradient-to-r from-slate-800 to-slate-900 text-slate-400 mt-16">
      <div class="max-w-7xl mx-auto px-4 py-8 text-center text-sm">
        <p>Taxmann Bookstore Scraper &mdash; Data sourced from <a href="https://www.taxmann.com/bookstore" class="text-indigo-400 hover:text-indigo-300" target="_blank">taxmann.com/bookstore</a></p>
      </div>
    </footer>
  </body>
</html>
